# Grafana file-provisioned alert rules — rendered by install.sh with an explicit
# envsubst variable list (${BATTERY_WARN} ${BATTERY_CRIT} ${ONLINE_THRESHOLD_SECONDS})
# so Grafana macros like $__timeFilter are untouched. OFFLINE_ALERT_SECONDS is no
# longer used here -- the offline-report rule below reports every offline device,
# tiered by duration, rather than firing past a single threshold.
# UIDs are hardcoded so re-provisioning updates rules instead of duplicating them.
# The folder "HMDM Stats" (uid hmdm-stats) is created by the dashboard provider.
apiVersion: 1

groups:
  - orgId: 1
    name: hmdm-fleet
    folder: HMDM Stats
    interval: 5m
    rules:
      - uid: hmdm-offline-report
        title: Offline devices report
        condition: C
        for: 0s
        noDataState: OK
        execErrState: Alerting
        labels:
          severity: warning
          source: hmdm-stats
          report: offline-summary
        annotations:
          summary: "{{ $labels.heading }} -- see the webhook/email body for the full device list."
        data:
          - refId: A
            relativeTimeRange: { from: 21600, to: 0 }
            datasourceUid: hmdm-postgres
            model:
              refId: A
              format: table
              rawQuery: true
              # One row per non-empty offline tier (<1h / 1-12h / >12h), each already fully
              # pre-formatted (heading with its count, and a newline-joined device list) so the
              # notification template just has to print each row -- no counting/filtering/
              # arithmetic needed in Grafana's template engine, which only reliably supports
              # basic range/if/index, not Sprig-style helpers.
              # Only devices with a genuine current owner (per their latest non-deleted ITAM log
              # entry) are reported at all -- unassigned/stock devices (blank owner, "N/A", or no
              # ITAM log entry) can sit offline indefinitely without ever appearing here.
              # The final SELECT always returns at least one row via a UNION ALL sentinel
              # ("tier='none', matched=0") when report_rows is empty. Grafana's reduce/threshold
              # expression pipeline throws an "input data must be a wide series" evaluation error
              # on a genuinely empty result table instead of cleanly treating it as "no data" --
              # with execErrState: Alerting (below), that error would incorrectly fire the rule
              # exactly when zero devices are offline. The sentinel keeps the query non-empty and
              # type-safe; its matched=0 always fails the "gt 0" threshold, so it never itself
              # fires or reaches the notification template -- zero real offline devices still
              # correctly means zero firing instances and no webhook that cycle.
              # IMPORTANT: this rawSql uses YAML's ">" folded scalar, which joins wrapped lines
              # with a single space -- do not add a SQL "--" line comment inside it (a "#" comment
              # above, like this one, is fine); a "--" comment here would silently swallow
              # everything up to the next real newline, since folding removes the line breaks a
              # "--" comment depends on to end.
              rawSql: >
                WITH latest AS (
                  SELECT DISTINCT ON (dsh.device_number) dsh.device_number, dsh.online, dsh.last_update
                  FROM device_status_history dsh
                  ORDER BY dsh.device_number, dsh.sampled_at DESC
                ),
                offline_devices AS (
                  SELECT device_number,
                         GREATEST(0, ROUND((extract(epoch FROM (now() - COALESCE(last_update, timestamptz 'epoch'))) / 3600.0)::numeric))::int AS hours_offline
                  FROM latest
                  WHERE NOT online
                ),
                latest_owner AS (
                  SELECT DISTINCT ON (d.number) d.number AS device_number, l.ownername
                  FROM devices d
                  JOIN plugin_itam_log l ON l.deviceid = d.id AND l.deletedat IS NULL
                  ORDER BY d.number, l.createdat DESC
                ),
                owners AS (
                  SELECT device_number, ownername
                  FROM latest_owner
                  WHERE ownername IS NOT NULL
                    AND trim(ownername) <> ''
                    AND upper(trim(ownername)) <> 'N/A'
                ),
                tiered AS (
                  SELECT o.device_number,
                         ow.ownername AS owner_name,
                         o.hours_offline,
                         CASE WHEN o.hours_offline < 1 THEN 'lt1h'
                              WHEN o.hours_offline < 12 THEN 'lt12h'
                              ELSE 'gt12h' END AS tier
                  FROM offline_devices o
                  JOIN owners ow ON ow.device_number = o.device_number
                ),
                totals AS (
                  SELECT count(*) AS total_offline FROM tiered
                ),
                report_rows AS (
                  SELECT tier,
                         (CASE tier
                              WHEN 'lt1h' THEN 'Offline < 1 hour'
                              WHEN 'lt12h' THEN 'Offline 1-12 hours'
                              ELSE 'Offline > 12 hours'
                          END || ' (' || count(*) || ' devices)') AS heading,
                         string_agg(device_number || ' -- ' || owner_name || ' -- ' || hours_offline || ' hours', '~~~' ORDER BY device_number) AS device_list,
                         (SELECT total_offline FROM totals) AS total_offline,
                         1 AS matched
                  FROM tiered
                  GROUP BY tier
                )
                SELECT tier, heading, device_list, total_offline, matched FROM report_rows
                UNION ALL
                SELECT 'none', '', '', 0, 0
                WHERE NOT EXISTS (SELECT 1 FROM report_rows)
                ORDER BY CASE tier WHEN 'gt12h' THEN 1 WHEN 'lt12h' THEN 2 WHEN 'lt1h' THEN 3 ELSE 4 END
          - refId: B
            datasourceUid: __expr__
            model:
              refId: B
              type: reduce
              expression: A
              reducer: last
          - refId: C
            datasourceUid: __expr__
            model:
              refId: C
              type: threshold
              expression: B
              conditions:
                # "matched" is always 1 -- a row existing (i.e. a non-empty tier) is itself
                # the condition; the real bucketing already happened in the SQL above.
                - evaluator: { type: gt, params: [0] }

      - uid: hmdm-battery-warn
        title: Battery low (warn tier)
        condition: C
        for: 0s
        noDataState: OK
        execErrState: Alerting
        labels:
          severity: warning
          source: hmdm-stats
        annotations:
          summary: "Device {{ $labels.device_number }} battery below ${BATTERY_WARN}% while online and not charging."
        data:
          - refId: A
            relativeTimeRange: { from: 21600, to: 0 }
            datasourceUid: hmdm-postgres
            model:
              refId: A
              format: table
              rawQuery: true
              rawSql: "WITH latest AS (SELECT DISTINCT ON (device_number) device_number, battery_level, charging, online FROM device_status_history ORDER BY device_number, sampled_at DESC) SELECT device_number, battery_level FROM latest WHERE online AND charging IS NULL AND battery_level IS NOT NULL"
          - refId: B
            datasourceUid: __expr__
            model:
              refId: B
              type: reduce
              expression: A
              reducer: last
          - refId: C
            datasourceUid: __expr__
            model:
              refId: C
              type: threshold
              expression: B
              conditions:
                - evaluator: { type: lt, params: [${BATTERY_WARN}] }

      - uid: hmdm-battery-crit
        title: Battery critically low (freeze tier)
        condition: C
        for: 0s
        noDataState: OK
        execErrState: Alerting
        labels:
          severity: critical
          source: hmdm-stats
        annotations:
          summary: "Device {{ $labels.device_number }} battery below ${BATTERY_CRIT}% — FreeKiosk freeze tier."
        data:
          - refId: A
            relativeTimeRange: { from: 21600, to: 0 }
            datasourceUid: hmdm-postgres
            model:
              refId: A
              format: table
              rawQuery: true
              rawSql: "WITH latest AS (SELECT DISTINCT ON (device_number) device_number, battery_level, charging, online FROM device_status_history ORDER BY device_number, sampled_at DESC) SELECT device_number, battery_level FROM latest WHERE online AND charging IS NULL AND battery_level IS NOT NULL"
          - refId: B
            datasourceUid: __expr__
            model:
              refId: B
              type: reduce
              expression: A
              reducer: last
          - refId: C
            datasourceUid: __expr__
            model:
              refId: C
              type: threshold
              expression: B
              conditions:
                - evaluator: { type: lt, params: [${BATTERY_CRIT}] }

      - uid: hmdm-data-stale
        title: Snapshot pipeline stale
        condition: C
        for: 0s
        noDataState: Alerting
        execErrState: Alerting
        labels:
          severity: critical
          source: hmdm-stats
        annotations:
          summary: "No new device_status_history rows for over ${ONLINE_THRESHOLD_SECONDS} seconds — the snapshot cron job is not writing. Check /var/log/hmdm-stats/snapshot.log."
        data:
          - refId: A
            relativeTimeRange: { from: 21600, to: 0 }
            datasourceUid: hmdm-postgres
            model:
              refId: A
              format: table
              rawQuery: true
              rawSql: "SELECT COALESCE(extract(epoch FROM (now() - max(sampled_at))), 999999) AS staleness_seconds FROM device_status_history"
          - refId: B
            datasourceUid: __expr__
            model:
              refId: B
              type: reduce
              expression: A
              reducer: last
          - refId: C
            datasourceUid: __expr__
            model:
              refId: C
              type: threshold
              expression: B
              conditions:
                - evaluator: { type: gt, params: [${ONLINE_THRESHOLD_SECONDS}] }

# File-provisioning only adds/updates rules matching a UID present above -- it does NOT
# delete a rule whose UID disappeared from an earlier version of this file. The old
# single-threshold "Device offline too long" rule (uid hmdm-offline-1h) predates the
# tiered "Offline devices report" rule and must be explicitly retired here, or it keeps
# firing forever alongside the new one.
deleteRules:
  - orgId: 1
    uid: hmdm-offline-1h
