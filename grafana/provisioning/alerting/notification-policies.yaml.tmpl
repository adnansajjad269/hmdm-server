# Default notification policy — routes everything from the hmdm-fleet rule
# group to the hmdm-alerts contact point. Rendered/installed by install.sh only
# when at least one of ALERT_EMAIL_TO / ALERT_WEBHOOK_URL is configured.
apiVersion: 1

policies:
  - orgId: 1
    receiver: hmdm-alerts
    group_by: ["alertname", "device_number"]
    group_wait: 30s
    group_interval: 5m
    repeat_interval: 4h
