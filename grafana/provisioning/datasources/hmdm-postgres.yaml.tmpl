# Rendered by install.sh (envsubst) into /etc/grafana/provisioning/datasources/
# Read-only role: grafana_ro has SELECT on device_status_history only.
apiVersion: 1

datasources:
  - name: HMDM Postgres
    uid: hmdm-postgres          # pinned: dashboard JSON and alert rules reference this
    type: grafana-postgresql-datasource
    access: proxy
    url: 127.0.0.1:5432
    user: grafana_ro
    isDefault: true
    editable: false
    jsonData:
      database: ${HMDM_DB_NAME}
      sslmode: disable
      maxOpenConns: 4
      maxIdleConns: 2
      connMaxLifetime: 14400
      postgresVersion: 1200
      timescaledb: false
    secureJsonData:
      password: "${HMDM_GRAFANA_RO_PASSWORD}"
